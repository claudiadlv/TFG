        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Usuario\&quot; as User\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nUser -&gt; FE: Accede a la pantalla de calendario\nFE -&gt; FE: Verificar rol guardado en Context API\n\nalt El rol no es Entrenador\n    FE -&gt; FE: Ocultar boton de Crear Evento\n    FE --&gt; User: Renderizar unicamente la vista de consulta\nelse El rol es Entrenador\n    FE -&gt; FE: Mostrar boton de Crear Evento\nend\n\nUser -&gt; FE: Presiona el boton Crear Evento\nFE --&gt; User: Mostrar formulario de creacion de evento\nUser -&gt; FE: Rellena los campos obligatorios y confirma\nFE -&gt; BE: POST /api/events\nactivate BE\n\nBE -&gt; BE: Validar firma del token JWT y confirmar rol de Entrenador en servidor\n\nalt Token invalido o rol no autorizado en backend\n    BE --&gt; FE: HTTP 403 Forbidden\n    FE --&gt; User: Mostrar alerta de permisos denegados\n    destroy BE\nend\n\nBE -&gt; BE: Verificar campos obligatorios y comprobar conflictos horarios\n\nalt Datos invalidos o conflicto de fecha\n    BE --&gt; FE: HTTP 400 Bad Request\n    FE --&gt; User: Mostrar alerta de datos incorrectos\n    destroy BE\nend\n\nBE -&gt; DB: INSERT INTO eventos (fecha, hora, tipo, categoria, nombreCarrera, disciplina)\nactivate DB\nDB --&gt; BE: Confirmacion de guardado persistente\ndeactivate DB\n\nBE --&gt; FE: HTTP 201 Created\ndeactivate BE\n\nFE -&gt; FE: Actualizar el estado del calendario en Context API\nFE --&gt; User: Renderizar la nueva tarjeta en la agenda movil\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Sbj6gJAUyFqc86Cjwsoq-1">
