        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Padre / Tutor legal\&quot; as Padre\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nPadre -&gt; FE: Accede al apartado de rendimiento y estadisticas de su hijo\nFE -&gt; BE: GET /api/analytics/charts/deportista/:id\nactivate BE\n\nBE -&gt; BE: Validar firma del token JWT del Padre\n\nalt Token invalido o sesion expirada\n    BE --&gt; FE: HTTP 401 Unauthorized\n    FE --&gt; Padre: Mostrar alerta de sesion caducada\n    destroy BE\nend\n\nBE -&gt; DB: SELECT * FROM deportistas WHERE id = id_deportista AND padre_id = id_padre\nactivate DB\nDB --&gt; BE: Retorna confirmacion de parentesco y datos del menor\ndeactivate DB\n\nBE -&gt; DB: SELECT * FROM eventos WHERE categoria_id = id_categoria\nactivate DB\nDB --&gt; BE: Retorna el listado de entrenamientos de su categoria\ndeactivate DB\n\nBE -&gt; BE: Calcular la tasa de participacion y asistencia del deportista\n\nalt No hay suficientes registros en el historico\n    BE --&gt; FE: HTTP 200 OK con datos vacios\n    FE --&gt; Padre: Mostrar mensaje informando que aun no hay graficos disponibles\n    destroy BE\nend\n\nBE --&gt; FE: HTTP 200 OK con las metricas calculadas\ndeactivate BE\n\nFE -&gt; FE: Inyectar las metricas en el componente de graficas de React Native\nFE --&gt; Padre: Renderizar en la pantalla el grafico circular de asistencia del menor\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="IQMauV-WWaxgMb0x2Ufe-1">
