        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Padre / Tutor legal\&quot; as Padre\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nPadre -&gt; FE: Accede a la pantalla de registro\nPadre -&gt; FE: Introduce datos en el formulario\nPadre -&gt; FE: Presiona Enviar Registro\n\nFE -&gt; BE: POST /api/auth/register (JSON con datos)\nactivate BE\n\nBE -&gt; BE: Validar formato de correo y campos obligatorios\n\nalt Datos inválidos\n    BE --&gt; FE: HTTP 400 Bad Request (Mensaje de error)\n    FE --&gt; Padre: Mostrar alerta de campos incorrectos\nelse Datos válidos\n    BE -&gt; DB: SELECT id FROM usuarios WHERE email = ?\n    activate DB\n    DB --&gt; BE: Retorna coincidencia (si existe)\n    deactivate DB\n    \n    alt Correo ya registrado\n        BE --&gt; FE: HTTP 409 Conflict (Correo duplicado)\n        FE --&gt; Padre: Mostrar mensaje de correo ya dado de alta\n    else Correo disponible\n        BE -&gt; BE: Encriptar contraseña con bcrypt\n        BE -&gt; DB: INSERT INTO solicitudes_registro (nombre, email, password_hash, estado)\n        activate DB\n        DB --&gt; BE: Confirmación de inserción exitosa\n        deactivate DB\n        \n        BE --&gt; FE: HTTP 201 Created (Solicitud almacenada)\n        deactivate BE\n        \n        FE --&gt; Padre: Refrescar interfaz y mostrar pantalla de confirmación\n    end\nend\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Sz7Cvew0IAP9qOSUs4IR-1">
