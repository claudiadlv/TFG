        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Padre / Tutor legal\&quot; as Padre\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nPadre -&gt; FE: Accede a la pantalla de registro\nPadre -&gt; FE: Introduce datos en el formulario\nPadre -&gt; FE: Presiona Enviar Registro\n\nFE -&gt; BE: POST /api/auth/register (JSON con datos)\nactivate BE\n\nBE -&gt; BE: Validar formato de correo y campos obligatorios\n\nalt Datos invalidos\n    BE --&gt; FE: HTTP 400 Bad Request\n    FE --&gt; Padre: Mostrar alerta de campos incorrectos\n    destroy BE\nend\n\nBE -&gt; DB: SELECT id FROM usuarios WHERE email = ?\nactivate DB\nDB --&gt; BE: Retorna coincidencia si existe\ndeactivate DB\n\nalt Correo ya registrado\n    BE --&gt; FE: HTTP 409 Conflict\n    FE --&gt; Padre: Mostrar mensaje de correo ya dado de alta\n    destroy BE\nend\n\nBE -&gt; BE: Encriptar contraseña con bcrypt\nBE -&gt; DB: INSERT INTO solicitudes_registro (nombre_tutor, apellidos_tutor, correo_tutor, nombre_hijo, apellido_hijo, fecha_nacimiento_hijo, password_hash, estado, categoria, fecha_nacimiento_tutor)\nactivate DB\nDB --&gt; BE: Confirmacion de insercion exitosa\ndeactivate DB\n\nBE --&gt; FE: HTTP 201 Created\ndeactivate BE\n\nFE --&gt; Padre: Refrescar interfaz y mostrar pantalla de confirmacion\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Sz7Cvew0IAP9qOSUs4IR-1">
