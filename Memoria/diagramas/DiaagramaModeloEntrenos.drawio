        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam ArrowColor #2C3E50\nskinparam LineThickness 1.2\nskinparam roundcorner 5\n\n&#39; Estilos idénticos al modelado conceptual formal\nskinparam class {\n    BackgroundColor #F9F9F9\n    BorderColor #333333\n    FontColor #000000\n    AttributeIconSize 0\n    HeaderBackgroundColor #EFEFEF\n}\n\nclass \&quot;eventos\&quot; as eventos {\n    --\n    id : INT\n    fecha : DATE\n    hora : TIME\n    tipo : VARCHAR\n    categoria : VARCHAR\n    nombreCarrera : VARCHAR\n    disciplina : VARCHAR\n    viaje_id : INT\n}\n\nclass \&quot;eventos_deportistas\&quot; as asistencia {\n    --\n    id : INT\n    id_evento : INT\n    id_deportista : INT\n    enFurgoneta : TINYINT\n}\n\nclass \&quot;deportistas\&quot; as deportistas {\n    --\n    id : INT\n    nombre : VARCHAR\n    apellidos : VARCHAR\n}\n\n&#39; Relaciones conceptuales con cardinalidades\neventos ||-down-{ asistencia : \&quot;«1:N»\\nregistra\&quot;\ndeportistas ||-down-{ asistencia : \&quot;«1:N»\\nacude\&quot;\n\nnote bottom of asistencia\n  La entidad intermedia &lt;b&gt;eventos_deportistas&lt;/b&gt; resuelve\n  la relación muchos a muchos e integra el flag &lt;b&gt;enFurgoneta&lt;/b&gt;,\n  conectando la presencia en pista con las necesidades logísticas.\nend note\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="DrCg_orwchUkawLOTQo0-1">
