        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Admin / Entrenador\&quot; as Staff\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nStaff -&gt; FE: Accede al panel multimedia y presiona Cargar Imagen\nFE --&gt; Staff: Abre el selector de archivos nativo del dispositivo\nStaff -&gt; FE: Selecciona la imagen, elige la categoria y confirma\nFE -&gt; BE: POST /api/multimedia/upload (Multipart FormData con categoria)\nactivate BE\n\nBE -&gt; BE: Validar firma del token JWT y verificar rol autorizado\n\nalt Token invalido o sin permisos\n    BE --&gt; FE: HTTP 403 Forbidden\n    FE --&gt; Staff: Mostrar alerta de permisos denegados\n    destroy BE\nend\n\nBE -&gt; BE: Validar extension del archivo y consistencia de la categoria\n\nalt Archivo no admitido o categoria inexistente\n    BE --&gt; FE: HTTP 400 Bad Request\n    FE --&gt; Staff: Mostrar alerta de datos o archivo incorrecto\n    destroy BE\nend\n\nBE -&gt; BE: Mover archivo al almacenamiento del servidor y generar url\nBE -&gt; DB: INSERT INTO multimedia (ruta, fecha_creacion, categoria_id) VALUES (?, ?, ?)\nactivate DB\nDB --&gt; BE: Confirmacion de insercion exitosa\ndeactivate DB\n\nBE --&gt; FE: HTTP 201 Created\ndeactivate BE\n\nFE -&gt; FE: Refrescar la vista del catalogo de administracion\nFE --&gt; Staff: Mostrar notificacion de imagen cargada y categorizada con exito\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Fmo5NS9VcB1GinRCw97_-1">
