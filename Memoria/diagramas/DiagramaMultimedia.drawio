<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="DPYMgNejXftS4T4Y_pci">
    <mxGraphModel dx="1410" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam ArrowColor #2C3E50\nskinparam LineThickness 1.2\nskinparam roundcorner 5\n\n&#39; Estilos idénticos a tus cajas claras\nskinparam class {\n    BackgroundColor #F9F9F9\n    BorderColor #333333\n    FontColor #000000\n    AttributeIconSize 0\n    HeaderBackgroundColor #EFEFEF\n}\n\n&#39; Entidades principales del módulo (Foco del diagrama)\nclass \&quot;solicitudes_registro\&quot; as solicitudes #FFF2CC {\n    &lt;b&gt;Flujo de onboarding administrativo&lt;/b&gt;\n    --\n    id : INT [PK]\n    nombre_tutor : VARCHAR\n    apellidos_tutor : VARCHAR\n    correo_tutor : VARCHAR\n    nombre_hijo : VARCHAR\n    apellidos_hijo : VARCHAR\n    fecha_nacimiento_hijo : DATE\n    contrasena : VARCHAR\n    estado : VARCHAR\n    categoria : VARCHAR\n    fecha_nacimiento_tutor : DATE\n}\n\nclass \&quot;fotos\&quot; as fotos #E1F5FE {\n    &lt;b&gt;Archivo multimedia técnico&lt;/b&gt;\n    --\n    id : INT [PK]\n    ruta : VARCHAR\n    fecha_creacion : DATETIME\n    categoria_id : VARCHAR\n}\n\n&#39; Entidades de contexto externo (Solo contorno para dar trazabilidad)\nclass \&quot;usuarios\&quot; as usuarios &lt;&lt; (C,#EAFAF1) &gt;&gt; {\n    &lt;i&gt;Cuenta y sesión (Admin)&lt;/i&gt;\n}\nclass \&quot;entrenador\&quot; as entrenador &lt;&lt; (C,#EAFAF1) &gt;&gt; {\n    &lt;i&gt;Personal Técnico&lt;/i&gt;\n}\nclass \&quot;deportistas\&quot; as deportistas &lt;&lt; (C,#EAFAF1) &gt;&gt; {\n    &lt;i&gt;Ficha del Esquiador&lt;/i&gt;\n}\n\n&#39; --- RELACIONES DE TRÁNSITO Y AUTORÍA DEL MÓDULO ---\nsolicitudes .up.&gt; usuarios : \&quot;«tránsito al aprobar»\&quot;\nentrenador ..&gt; fotos : \&quot;«sube metraje» (1:N)\&quot;\nusuarios ..&gt; fotos : \&quot;«sube admin» (1:N)\&quot;\nfotos .left.&gt; deportistas : \&quot;«contexto técnico»\&quot;\n\n&#39; Notas que ya tienes perfectas\nnote bottom of solicitudes\n  La entidad &lt;b&gt;solicitudes_registro&lt;/b&gt; actúa de forma aislada como pasarela\n  de validación para el alta segura de nuevas familias, evitando introducir \n  datos en producción antes de la aprobación del administrador.\nend note\n\nnote bottom of fotos\n  La entidad &lt;b&gt;fotos&lt;/b&gt; almacena la indexación en servidor de las capturas \n  multimedia en nieve, vinculadas lógicamente a una categoría deportiva.\nend note\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="IijQEbkOgwasvFNG4kxZ-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="492" width="1045" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
