        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Entrenador\&quot; as Coach\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nCoach -&gt; FE: Selecciona un evento en el calendario\nFE -&gt; FE: Verificar rol del usuario en Context API\nFE --&gt; Coach: Mostrar detalles del evento con botones Editar y Eliminar\n\nalt El Entrenador selecciona Editar\n    Coach -&gt; FE: Modifica los campos del formulario y presiona Guardar\n    FE -&gt; BE: PUT /api/events/:id\n    activate BE\n    \n    BE -&gt; BE: Validar firma del token JWT y confirmar rol de Entrenador\n    alt Token invalido o sin permisos\n        BE --&gt; FE: HTTP 403 Forbidden\n        FE --&gt; Coach: Mostrar alerta de permisos denegados\n        destroy BE\n    end\n    \n    BE -&gt; BE: Validar nuevos campos obligatorios y conflicto horario\n    alt Datos incorrectos o fecha invalida\n        BE --&gt; FE: HTTP 400 Bad Request\n        FE --&gt; Coach: Mostrar alerta de datos invalidos\n        destroy BE\n    end\n    \n    BE -&gt; DB: UPDATE eventos SET fecha = ?, hora = ?, tipo = ?, categoria = ?, nombreCarrera = ?, disciplina = ? WHERE id = ?\n    activate DB\n    DB --&gt; BE: Confirmacion de actualizacion exitosa\n    deactivate DB\n    \n    BE --&gt; FE: HTTP 200 OK\n    deactivate BE\n    \n    FE -&gt; FE: Actualizar el estado global en Context API\n    FE --&gt; Coach: Mostrar notificacion de cambios guardados\n    \nelse El Entrenador selecciona Eliminar\n    Coach -&gt; FE: Presiona Eliminar y confirma en la ventana emergente\n    FE -&gt; BE: DELETE /api/events/:id\n    activate BE\n    \n    BE -&gt; BE: Validar firma del token JWT y confirmar rol de Entrenador\n    alt Token invalido o sin permisos\n        BE --&gt; FE: HTTP 403 Forbidden\n        FE --&gt; Coach: Mostrar alerta de permisos denegados\n        destroy BE\n    end\n    \n    BE -&gt; DB: DELETE FROM eventos WHERE id = ?\n    activate DB\n    DB --&gt; BE: Confirmacion de eliminacion exitosa\n    deactivate DB\n    \n    BE --&gt; FE: HTTP 200 OK\n    deactivate BE\n    \n    FE -&gt; FE: Eliminar el evento del calendario local\n    FE --&gt; Coach: Mostrar notificacion de evento cancelado\nend\n@endum &quot;,&quot;format&quot;:&quot;svg&quot;}" id="k8ohg6VRy8VyX3z3BFAI-1">
