        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam responseMessageBelowArrow true\n\nactor \&quot;Administrador\&quot; as Admin\nparticipant \&quot;Frontend\\n(React Native)\&quot; as FE\nparticipant \&quot;Backend\\n(Express API)\&quot; as BE\ndatabase \&quot;Base de Datos\\n(MySQL)\&quot; as DB\n\nautonumber\n\nAdmin -&gt; FE: Accede al panel de administrar solicitudes\nFE -&gt; BE: GET /api/admin/requests\nactivate BE\n\nBE -&gt; BE: Validar firma del token y rol de Administrador\n\nalt Token invalido o sin permisos\n    BE --&gt; FE: HTTP 403 Forbidden\n    FE --&gt; Admin: Mostrar alerta de error de permisos\n    destroy BE\nend\n\nBE -&gt; DB: SELECT * FROM solicitudes WHERE estado = &#39;PENDIENTE&#39;\nactivate DB\nDB --&gt; BE: Retorna listado de solicitudes pendientes\ndeactivate DB\n\nBE --&gt; FE: HTTP 200 OK\nFE --&gt; Admin: Renderizar lista de peticiones en pantalla\n\nAdmin -&gt; FE: Selecciona una solicitud y presiona Aceptar Solicitud\nFE -&gt; BE: POST /api/admin/requests/approve/id\n\nBE -&gt; BE: Validar permisos del Administrador para la acción\nBE -&gt; DB: Iniciar transaccion SQL\nactivate DB\n\nBE -&gt; DB: UPDATE solicitudes SET estado = &#39;APROBADO&#39; WHERE id = id\nBE -&gt; DB: INSERT INTO usuarios (nombre, apellidos, correo, fecha_nacimiento, contrasena, rol) VALUES (...)\n\nDB --&gt; BE: Confirmar exito de la transaccion\ndeactivate DB\n\nBE --&gt; FE: HTTP 200 OK\ndeactivate BE\n\nFE --&gt; Admin: Eliminar solicitud de la lista y mostrar mensaje de exito\n@endum&quot;,&quot;format&quot;:&quot;svg&quot;}" id="iwi6MMf0_S0YsaUxy-ZR-1">
