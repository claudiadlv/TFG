        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam backgroundcolor transparent\nskinparam ArrowColor #2C3E50\nskinparam LineThickness 1.2\nskinparam roundcorner 5\n\n&#39; Estilos idénticos a la imagen de referencia (Cajas claras, texto centrado)\nskinparam class {\n    BackgroundColor #F9F9F9\n    BorderColor #333333\n    FontColor #000000\n    AttributeIconSize 0\n    HeaderBackgroundColor #EFEFEF\n}\n\nclass \&quot;usuarios\&quot; as users {\n    --\n    id : INT\n    nombre : VARCHAR\n    apellidos : VARCHAR\n    correo : VARCHAR\n    contrasena : VARCHAR\n    rol : ENUM\n    reset_password_token : VARCHAR\n    reset_password_expires : DATETIME\n}\n\nclass \&quot;padres\&quot; as parents {\n    --\n    id : INT\n    id_usuario : INT\n    nombre : VARCHAR\n    apellidos : VARCHAR\n    correo : VARCHAR\n}\n\nclass \&quot;entrenador\&quot; as coaches {\n    --\n    id : INT\n    categoria : VARCHAR\n}\n\nclass \&quot;padres_hijos\&quot; as parents_kids {\n    --\n    id : INT\n    id_padre : INT\n    id_deportista : INT\n}\n\nclass \&quot;deportistas\&quot; as kids {\n    --\n    id : INT\n    nombre : VARCHAR\n    apellidos : VARCHAR\n    fecha_nacimiento : DATE\n    categoria : VARCHAR\n}\n\n&#39; Relaciones con las mismas cardinalidades de la imagen de referencia\nusers ||-down-|| parents : \&quot;«1:1»\\nsi es tutor legal\&quot;\nusers ||-down-|| coaches : \&quot;«1:1»\\nsi es entrenador\&quot;\n\nparents ||-left-{ parents_kids : \&quot;«1:N»\\nfiliaciones\&quot;\nkids ||-up-{ parents_kids : \&quot;«1:N»\\ntutelas asignadas\&quot;\n\n&#39; Nota explicativa igual que la de la imagen GeoUGR\nnote bottom of parents_kids\n  Un esquiador menor no posee cuenta propia por seguridad.\n  La tabla intermedia &lt;b&gt;padres_hijos&lt;/b&gt; permite gestionar \nsus reservas de transporte y asistencias.\nend note\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="S8s2OuWPSw13Dt_-BCrY-1">
